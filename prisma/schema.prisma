generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  password    String
  name        String?
  role        Role         @default(USER)
  avatar      String?
  bio         String?
  location    String?
  socialLinks Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  comments    Comment[]
  experiences Experience[]
  projects    Project[]
  resumes     Resume[]
  skills      Skill[]
}

model Settings {
  id              Int     @id @default(1)
  siteName        String  @default("My Portfolio")
  siteDescription String?
  seoKeywords     String?
  contactEmail    String?
  isOpenToWork    Boolean @default(true)
  footerText      String?
  themeConfig     Json?
}

model Project {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  description String
  content     String?
  thumbnail   String?
  images      String[]
  techStack   String[]
  demoUrl     String?
  liveUrl     String?
  githubUrl   String?
  problem     String?
  decision    String?
  result      String?
  metrics     Json?
  isFeatured  Boolean       @default(false)
  tags        String[]
  userId      String
  status      ProjectStatus @default(DRAFT)
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id])
}

model Post {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String?
  content   String
  thumbnail String?
  tags      String[]
  published Boolean  @default(false)
  views     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Experience {
  id           String    @id @default(cuid())
  company      String
  position     String
  location     String?
  description  String?
  startDate    DateTime
  endDate      DateTime?
  isCurrent    Boolean   @default(false)
  type         ExpType   @default(WORK)
  userId       String
  order        Int       @default(0)
  achievements String[]
  coursework   String[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id])
}

model SkillGroup {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  color       String   @default("#3b82f6")
  icon        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  skills      Skill[]
}

model Skill {
  id            String      @id @default(cuid())
  name          String
  iconUrl       String?
  iconPublicId  String?
  proficiency   Int         @default(75)
  level         String      @default("Intermediate")
  whenToUse     String?
  whyItMatters  String?
  isHighlighted Boolean     @default(false)
  order         Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  groupId       String?
  userId        String
  group         SkillGroup? @relation(fields: [groupId], references: [id])
  user          User        @relation(fields: [userId], references: [id])
}

model Resume {
  id        String   @id @default(cuid())
  title     String
  fileUrl   String
  version   String?
  isPrimary Boolean  @default(false)
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  content   String
  read      Boolean  @default(false)
  replied   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Media {
  id        String   @id @default(cuid())
  url       String
  publicId  String
  name      String
  size      Int
  type      String
  createdAt DateTime @default(now())
}

model Comment {
  id        String    @id @default(cuid())
  content   String
  userId    String
  postId    String?
  parentId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  parent    Comment?  @relation("CommentToComment", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentToComment")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum Role {
  ADMIN
  USER
  GUEST
  DEVELOPER
}

enum SkillCategory {
  FRONTEND
  BACKEND
  DATABASE
  DEVOPS
  TOOL
  OTHER
}

enum ExpType {
  WORK
  EDUCATION
  FREELANCE
  INTERNSHIP
  CONTRACT
}
